# Elasticsearch Configuration
# Get these from your Elastic Cloud console: https://cloud.elastic.co

# Option 1: Use Cloud ID (recommended for Elastic Cloud)
ELASTIC_CLOUD_ID=your-cloud-id-here

# Option 2: Use direct URL (for self-managed)
# ELASTIC_NODE=https://your-cluster:9200

# Authentication - Use API Key (recommended)
ELASTIC_API_KEY=your-api-key-here

# Or use username/password
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=your-password-here
